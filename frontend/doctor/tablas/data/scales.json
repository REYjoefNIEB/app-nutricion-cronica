          ],
          "min": 0.1, "max": 60, "step": 0.01, "default": 1.0, "required": true,
          "warningRange": { "below": 0.1, "above": 50, "message": "Valor fuera de rango clínico habitual. ¿Verificaste las unidades?" }
        },
